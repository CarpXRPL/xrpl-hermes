# xrpl-hermes — Optional Environment Variables
# Copy to .env and fill in your values (none required for read-only usage)

# Private XRPL Clio/rippled endpoint (optional — uses public endpoints by default)
# XRPL_PRIVATE_RPC=https://your-clio-node.com

# XRPL testnet wallet seed (optional — for example scripts)
# XRPL_SEED=sEd...

# XRPLSCAN API key (optional — for enhanced data queries)
# XRPLSCAN_API_KEY=***

# xrpl.to API key (optional — for higher token data rate limits)
# XRPL_TO_API_KEY=***
