# xrpl-hermes — Optional Environment Variables
# Copy to .env and fill in your values (none required for read-only usage)

# XRPL testnet funding key (optional — for building/signing transactions)
# XRPL_WALLET_SEED=sEd...

# EVM Sidechain private key (optional — for EVM contract operations)
# PRIVATE_KEY=0x...

# Xaman API credentials (optional — for deeplink payload creation)
# XAMAN_API_KEY=your_key
# XAMAN_API_SECRET=your_secret
